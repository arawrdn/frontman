  "ppx-flags": ["sury-ppx/bin"],
  "dependencies": [
    "sury"
  ],
  "dev-dependencies": [
    "rescript-vitest"
  ],
  "reanalyze": {
    "analysis": ["dce"],
    "unsuppress": [],
    "transitive": true
  },
  "compiler-flags": []
}
