{
	"name": "@ask-the-llm/client",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "npm run clean && run-p dev:build:watch dev:copy:watch dev:server",
		"dev:build:watch": "vite build --mode development --watch",
		"dev:copy:watch": "chokidar 'dist/ask-the-llm.es.js' -c 'npm run copy-bundle'",
		"dev:server": "vite",
		"copy-bundle": "cp dist/ask-the-llm.es.js public/ && cp dist/ask-the-llm.es.js public/bundle.es.js",
		"dev:hot": "vite --mode development",
		"dev:clean": "vite",
		"build": "npm run clean && tsc -b && vite build",
		"build:lib": "npm run clean && vite build --mode library",
		"clean": "rm -rf dist && tsc -b --clean",
		"serve": "vite preview --port 5173 --host",
		"lint": "eslint .",
		"preview": "vite preview"
	},
	"dependencies": {
		"@medv/finder": "^4.0.2",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-icons": "^1.3.2",
		"@zumer/snapdom": "^1.9.11",
		"error-stack-parser": "^2.1.4",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"source-map-js": "^1.2.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.36.0",
		"@types/node": "^22.0.0",
		"@types/react": "^19.1.13",
		"@types/react-dom": "^19.1.9",
		"@vitejs/plugin-react": "^5.0.3",
		"chokidar-cli": "^3.0.0",
		"eslint": "^9.36.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"globals": "^16.4.0",
		"npm-run-all": "^4.1.5",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.44.0",
		"vite": "^7.1.7"
	}
}
