{
	"name": "ask-the-llm",
	"namespace": true,
	"dependencies": [
		"@ask-the-llm/chrome-extension",
		"@ask-the-llm/bindings",
		"@ask-the-llm/client",
		"@ask-the-llm/frontman-client",
		"@ask-the-llm/frontman-nextjs",
		"@ask-the-llm/frontman-protocol",
		"@ask-the-llm/react-statestore",
		"@rescript/webapi"
	],
	"package-specs": {
		"module": "esmodule",
		"in-source": true
	},
	"jsx": {
		"version": 4
	},
	"gentypeconfig": {
		"language": "typescript",
		"module": "esmodule",
		"shims": {
			"JsxDOM": "JsxDOM"
		}
	},
	"suffix": ".res.mjs",
	"compiler-flags": []
}
