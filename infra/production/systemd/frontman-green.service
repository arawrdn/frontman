[Unit]
Description=Frontman Server (green slot - port 4001)
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=exec
User=deploy
Group=deploy
WorkingDirectory=/opt/frontman/green/current
EnvironmentFile=/opt/frontman/green/env
ExecStart=/opt/frontman/green/current/bin/server
ExecStop=/opt/frontman/green/current/bin/frontman_server stop
Restart=on-failure
RestartSec=5

# BEAM handles SIGTERM gracefully - drains connections, stops supervision tree
KillMode=process
TimeoutStopSec=30

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/opt/frontman/green
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
